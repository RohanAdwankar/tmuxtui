#!/usr/bin/expect -f

if {$argc != 2} {
    puts stderr "usage: empty_tmux.exp <binary> <tmux_tmpdir>"
    exit 2
}

set binary [lindex $argv 0]
set tmux_tmpdir [lindex $argv 1]

set env(TMUX_TMPDIR) $tmux_tmpdir
set env(TERM) "xterm-256color"
set timeout 20

spawn -noecho $binary

after 1500
send -- "q"
expect eof
