#!/usr/bin/expect -f

if {$argc != 4} {
    puts stderr "usage: split_orientation.exp <binary> <tmux_tmpdir> <split_key> <result_file>"
    exit 2
}

set binary [lindex $argv 0]
set tmux_tmpdir [lindex $argv 1]
set split_key [lindex $argv 2]
set result_file [lindex $argv 3]

set env(TMUX_TMPDIR) $tmux_tmpdir
set env(TERM) "xterm-256color"
set timeout 20

spawn -noecho $binary

after 1500
send -- $split_key
after 1000
send -- "\r"
after 1500
send -- "tmux list-panes -F '#{pane_left} #{pane_top}' > '$result_file'\r"

for {set attempt 0} {$attempt < 100} {incr attempt} {
    if {[file exists $result_file]} {
        exit 0
    }
    after 100
}

puts stderr "timed out waiting for result file"
exit 1
